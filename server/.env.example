PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-address>/worksphere?retryWrites=true&w=majority
NODE_ENV=development

# SMTP Configuration (Brevo SMTP is default placeholder)
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_smtp_user_email
MAIL_PASS=your_smtp_pass_key
MAIL_FROM=no-reply@worksphere.com
CLIENT_URL=http://localhost:5173

